{
  "name": "lutfi/pintarnya-backend",
  "description": "Pintarnya Backend API with Laravel",
  "type": "project",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0",
    "laravel/sanctum": "^3.0",
    "laravel/tinker": "^2.8"
  },
  "require-dev": {
    "fakerphp/faker": "^1.9.1",
    "phpunit/phpunit": "^10.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
